#include <bits/stdc++.h>
using namespace std;
using ll = long long;

int main(){
    ios_base:: sync_with_stdio(0); cin.tie(0);
    ll tiempo = 0;
    int libros = 0, pivot = 0 , cont = 0;
    cin >> libros >> tiempo;
    int v[libros];
    for(int i= 0; libros > i; i++){
        cin >> v[i];
    }
    for (int i = 0; libros > i; i++){
        if (tiempo >= v[i]){
            tiempo -= v[i];
            cont++;
        }
    }
    cout << cont;
}
